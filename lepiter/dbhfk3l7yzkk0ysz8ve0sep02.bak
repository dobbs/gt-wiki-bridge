					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-12T00:30:12.864721-06:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-23T16:19:49.01765-06:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "cT7VQ0J0Rw2ZA+54aqkTaA=="
				},
				"code" : "(wikiClientLib entries collect: [ :each | \r  | stream ast message |\r  stream := each readStream.\r  ast := JSParser\tparseStream: stream \r    onError: [ :str :pos | message := (str , ' ' , pos asString) ].\r\t{\r  \t'file' -> each basename .\r  \t'ast' -> ast . \r    'error' -> message\r\t} asDictionary\r])"
			},
