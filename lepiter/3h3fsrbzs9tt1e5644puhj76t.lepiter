					"uidString" : "KFrR+MRpReKYjENfsqC5dA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "##wiki-client [[wiki-client]]\nremove jquery-ui. A key behavior is drag-n-drop of pages in the lineup and items in the page.\nalternate slug computation. especially to enable page titles for other human languages \nalternate linup serialization to urls. especially to improve wiki-ssg"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
