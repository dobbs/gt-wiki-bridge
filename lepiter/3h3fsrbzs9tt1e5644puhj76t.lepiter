					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-11T22:34:05.613281-06:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
