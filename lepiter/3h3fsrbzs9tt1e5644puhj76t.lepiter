				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "rBQ7Ge2XS8yDYF9uUbQ9KA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "##wiki-server\nmaybe create an alternate CLI with simpler config params and local farm by default\nmaybe create a config generator CLI to make the existing config easier to set up"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
