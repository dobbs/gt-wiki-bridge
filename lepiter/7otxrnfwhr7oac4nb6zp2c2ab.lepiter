				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "I learned enough to make better use of GT's molded tools in JSParser."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
