								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-07-19T08:43:15.782227-06:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-07-19T08:47:59.610442-06:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "RGYQpmvUREO3Frn0XFYrPg=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "One might also start a tutorial from an existing parser, like {{gtClass:TestParser}} to teach the reader how to use the custom inspector before teaching the details of scanners and parsers."
						}
					]
				},
