					"uidString" : "l60QgVoKRpeEW8j5E5HdCA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "First questions to explore: If I change JSParser, how do I test my changes? How do I confirm I haven't broken other parsing?"
			},
			{
				"__type" : "textSnippet",
				"children" : {
